# AWS Cognito — copy values from AWS Console → Cognito → User Pool → App Integration
# Leave blank to run the app without authentication (dev / CI mode)
VITE_AWS_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS Cognito Identity Pool — required for Amplify Storage (S3) credential provisioning
# Console → Cognito → Identity Pools → your pool → overview page
# Both VITE_S3_BUCKET and VITE_COGNITO_IDENTITY_POOL_ID must be set to enable cloud save/load
VITE_COGNITO_IDENTITY_POOL_ID=us-east-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# AWS S3 — bucket for cloud plan storage (leave blank to disable cloud save/load)
# Bucket must allow authenticated Cognito users to read/write under plans/{userId}/
VITE_S3_BUCKET=your-tcp-plans-bucket

# PostHog analytics — leave blank to disable (dev / CI mode)
# Get your key at posthog.com → Project Settings → Project API Key
VITE_POSTHOG_KEY=

