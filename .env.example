# Backend environment variables
# For local development: copy to backend/.env and run uvicorn
# For Lambda: set these in samconfig.toml parameter_overrides or AWS console

# Comma-separated allowed CORS origins ("*" for local dev)
ALLOWED_ORIGINS=*

# GitHub fine-grained PAT with issues:write scope (for feedback portal)
GITHUB_TOKEN=github_pat_...

# GitHub repo for issue creation (owner/repo)
GITHUB_REPO=jfisher94002/TrafficControlPlanner

# S3 bucket name for sign SVG assets (set after `sam deploy`)
ASSETS_BUCKET=tcp-assets-dev-<account-id>
